;
; CDDL (RFC 8610) for the Selective Disclosure Report Ledger STATEMENT wire
; format: our profile of SD-CWT (draft-ietf-spice-sd-cwt), built on COSE
; (RFC 9052) and CWT (RFC 8392).
;
; This is the language-neutral contract that BOTH implementations conform to:
;   * app/src/token/   (C++, authoritative in-enclave signer/redactor)
;   * tools/sd_cwt/     (Python reference oracle + offline verifier)
; The cross-language conformance tests (tools/sd_cwt/tests/test_cpp_conformance.py)
; enforce byte-identical output; this file documents what those bytes are.
;
; Prose/rationale lives in docs/DESIGN.md (§1, §8) and docs/API.md.

; ==========================================================================
; Statement = a redacted SD-CWT (a COSE_Sign1), optionally made "transparent"
; by embedding the CCF receipt, optionally "presented" with disclosures.
; ==========================================================================

; A COSE_Sign1 (RFC 9052) tagged with 18.
statement = #6.18([
  protected   : bstr .cbor protected-header,   ; signed
  unprotected : unprotected-header,            ; NOT signed (receipt/disclosures)
  payload     : bstr .cbor claims,             ; signed: the (redacted) CWT claims
  signature   : bstr,                          ; issuer ECDSA over the Sig_structure
])

; --- Protected header (signed) --------------------------------------------
; Emitted in CDE key order (RFC 8949 4.2): 1 < 16 < 170.
protected-header = {
  1   : cose-alg,       ; COSE algorithm (issuer signature)
  16  : 293,            ; typ = application/sd-cwt
  170 : sd-alg,         ; SD-CWT redaction hash algorithm
}

cose-alg = &(
  ES256: -7,
  ES384: -35,
  ES512: -36,
)

sd-alg = &(
  SHA-256: -16,
  SHA-384: -43,
  SHA-512: -44,
)

; --- Unprotected header (NOT signed) --------------------------------------
; `sd_claims` (17): the disclosures the holder chose to present (absent/omitted
;   when none are presented -- draft-08 s8 forbids an empty sd_claims).
; `receipts` (394): CCF transparency receipt(s), embedded to make a "transparent
;   statement". Present on the /statements and /operator/statements responses.
unprotected-header = {
  ? 17  : [+ disclosure],   ; sd_claims -- MUST be non-empty when present
  ? 394 : [+ receipt],      ; embedded COSE receipt(s)
}

; A CCF receipt as a standalone COSE_Sign1 over the signed Merkle tree root,
; carrying the inclusion proof. Opaque here; see the CCF receipt profile.
receipt = #6.18([bstr, header-map, bstr / nil, bstr])
header-map = { * (int / tstr) => any }

; ==========================================================================
; Claims = the CWT claims set, after redaction.
; Clear claims stay as key => value. Every content field is redacted: its
; value is removed and a Redacted Claim Hash is appended to the simple(59)
; array, so a statement leaks neither which nor how many content fields it
; carried (strict uniformity -- DESIGN.md 1). A field that has been *disclosed*
; (via sd_claims) is resolved back to `content-key => value` by a verifier.
; ==========================================================================

claims = {
  1        : tstr,             ; iss -- the service identity (constant)
  6        : int,              ; iat -- issued-at (untrusted host wall-clock)
  #7.59    => [* redacted-hash],  ; redacted_claim_keys: hashes of redacted entries
  * content-key => any,       ; only appears for fields resolved from a disclosure
}

; The CBOR simple value 59 (#7.59) marks redacted map keys; the array holds a
; Redacted Claim Hash per redacted entry, sorted (CDE), so real-vs-decoy order
; is hidden.
redacted-hash = bstr          ; = sd-alg( bstr .cbor disclosure )

; Content field IDs (private-use claim keys). Every statement carries all of
; them (real or garbage-padded), all redacted -- see DESIGN.md 8.
content-key = &(
  parent:      1000,   ; SHA-256 of a parent statement's token (follow-up link)
  title:       1001,
  body:        1002,
  component:   1003,
  severity:    1004,
  fingerprint: 1005,
  references:  1006,
  patch:       1007,
  patch_date:  1008,
)

; ==========================================================================
; Disclosures -- the openings a holder presents (in sd_claims) or the service
; retains (confidential store). Each is a bstr wrapping a CBOR array.
;
; A redacted MAP entry contributes a Redacted Claim Hash (bstr) to the #7.59
; array (above); its opening is [salt, value, key]. A redacted ARRAY element is
; instead left in place inside its (disclosed) array value as tag(60) wrapping
; its hash -- CDDL `#6.60(redacted-hash)` -- and its opening is [salt, value].
; ==========================================================================

disclosure = bstr .cbor disclosure-opening

disclosure-opening =
    map-disclosure       ; a redacted map entry:    [salt, value, key]
  / element-disclosure   ; a redacted array element:[salt, value]
  / decoy-disclosure     ; salt-only padding:       [salt]

map-disclosure     = [salt, value: any, key: (int / tstr)]
element-disclosure = [salt, value: any]
decoy-disclosure   = [salt]

salt = bstr .size 16    ; 128-bit CSPRNG salt, one per disclosure
