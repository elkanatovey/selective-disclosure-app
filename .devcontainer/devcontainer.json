{
  // Dev container for the Selective Disclosure App.
  // Reuses the same toolchain-only image as docker/dev.sh (built from the repo
  // Dockerfile). The repo is bind-mounted at /workspace; you edit and build
  // entirely inside the container, with full clangd IntelliSense and lldb.
  "name": "sda-dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },

  // Mirror docker/dev.sh: mount the repo at /workspace and grant the caps that
  // CCF's sandbox.sh needs to set up its local network (and attach a debugger).
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "workspaceFolder": "/workspace",
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--cap-add=SYS_PTRACE"
  ],

  // Install a matching CCF release and build the app so the interactive web demo
  // (./demo/run_web_demo.sh) is runnable out of the box — the base image ships
  // only the toolchain. Runs once when the container is created.
  "postCreateCommand": "bash .devcontainer/post-create.sh",

  // The web demo serves on 8080; the CCF sandbox node listens on 8000.
  "forwardPorts": [8080, 8000],
  "portsAttributes": {
    "8080": { "label": "SD web demo", "onAutoForward": "openBrowser" },
    "8000": { "label": "CCF node", "onAutoForward": "silent" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cmake-tools",
        "vadimcn.vscode-lldb"
      ],
      "settings": {
        "clangd.path": "/usr/bin/clangd",
        "clangd.arguments": [
          "--background-index",
          "--header-insertion=never",
          "--clang-tidy"
        ]
      }
    }
  }
}
